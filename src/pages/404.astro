---
// Standalone page — no Layout
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Page Not Found | Jeremy × Aira</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root { color-scheme: dark; }

      body {
        min-height: 100dvh;
        background: #0e0c12;
        color: #cbd5e1;
        font-family: 'Inter', system-ui, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.25rem;
        overflow-x: hidden;
      }

      .blob {
        position: fixed;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
        filter: blur(120px);
      }
      .blob-1 {
        width: 500px; height: 500px;
        top: -15%; left: -10%;
        background: rgba(99, 102, 241, 0.12);
      }
      .blob-2 {
        width: 500px; height: 500px;
        bottom: -15%; right: -5%;
        background: rgba(168, 85, 247, 0.09);
      }

      .page {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 820px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
      }

      .label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: rgba(244, 114, 182, 0.45);
        margin-bottom: 0.6rem;
        position: relative;
      }

      .heading {
        font-size: clamp(2.4rem, 8vw, 5rem);
        font-weight: 900;
        letter-spacing: -0.04em;
        line-height: 1.1;
        background: linear-gradient(135deg, #fce7f3 0%, #c4b5fd 50%, #818cf8 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        padding: 0.05em 0.1em 0.1em;
        margin: 0 -0.1em 0.5rem;
        position: relative;
      }

      .sub {
        font-size: 0.9rem;
        color: rgba(148, 163, 184, 0.7);
        margin-bottom: 1.75rem;
        letter-spacing: 0.01em;
        position: relative;
      }

      .game-card {
        width: 100%;
        background: rgba(14, 12, 18, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 18px;
        padding: 14px;
        position: relative;
        overflow: hidden;
      }
      .game-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(244,114,182,0.03) 0%, transparent 60%);
        pointer-events: none;
        border-radius: 18px;
      }

      #game-canvas {
        display: block;
        width: 100%;
        aspect-ratio: 800 / 360;
        border-radius: 10px;
        cursor: pointer;
        image-rendering: pixelated;
        touch-action: none;
      }

      .hint {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(148, 163, 184, 0.35);
        text-align: center;
        margin-top: 0.9rem;
      }

      .home-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin-top: 1.75rem;
        padding: 0.6rem 1.4rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(203, 213, 225, 0.75);
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 9999px;
        text-decoration: none;
        transition: color 0.25s, background 0.25s, border-color 0.25s, box-shadow 0.25s;
      }
      .home-link:hover {
        color: #fce7f3;
        background: rgba(244, 114, 182, 0.08);
        border-color: rgba(244, 114, 182, 0.22);
        box-shadow: 0 0 20px rgba(244, 114, 182, 0.08);
      }
      .home-link svg {
        transition: transform 0.25s;
        flex-shrink: 0;
      }
      .home-link:hover svg { transform: translateX(-2px); }

      @media (max-width: 480px) {
        .game-card { padding: 10px; border-radius: 14px; }
        #game-canvas { border-radius: 7px; }
      }
    </style>
  </head>

  <body>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

    <div class="page">
      <p class="label">Error &middot; 404</p>
      <h1 class="heading">Page Not Found</h1>
      <p class="sub">迷路了？來玩個小遊戲放鬆一下吧。</p>

      <div class="game-card">
        <canvas id="game-canvas" width="800" height="360"></canvas>
      </div>

      <p class="hint" id="game-hint">Space / ↑ to jump &nbsp;·&nbsp; Double jump supported</p>

      <a href="/" class="home-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
        </svg>
        返回首頁
      </a>
    </div>

    <script>
      // Mobile hint
      if ('ontouchstart' in window) {
        const hint = document.getElementById('game-hint')
        if (hint) hint.textContent = 'Tap to jump  ·  Double jump supported'
      }

      const canvas = document.getElementById('game-canvas') as HTMLCanvasElement
      const ctx = canvas.getContext('2d')!

      // Logical canvas size (CSS aspect-ratio scales it)
      const W = 800
      const H = 360
      const GY = 295 // ground y

      // Colours
      const BG    = '#0d0b10'
      const DINO  = '#e2d9f3'
      const CACT  = '#f472b6'
      const CACTS = '#9d174d'
      const GND   = 'rgba(255,255,255,0.1)'
      const TXT2  = 'rgba(167,139,250,0.65)'

      type State = 'idle' | 'running' | 'dead'

      let state: State = 'idle'
      let score  = 0
      let hiScore = 0
      let tick   = 0
      let speed  = 0
      let spawnIn = 0

      const dino = {
        y: GY, vy: 0, grounded: true,
        jumps: 0,  // tracks double jump (max 2)
        dead: false,
        leg: 0, legTimer: 0,
      }

      type Obstacle = { x: number; w: number; h: number }
      type Cloud    = { x: number; y: number; w: number }

      let obs: Obstacle[] = []
      let clouds: Cloud[] = [
        { x: 180, y: 44, w: 80 },
        { x: 480, y: 32, w: 64 },
        { x: 680, y: 52, w: 56 },
      ]

      function jump() {
        if (state === 'idle' || state === 'dead') { resetGame(); return }
        if (dino.jumps < 2) {
          dino.vy = dino.jumps === 0 ? -15 : -11
          dino.grounded = false
          dino.jumps++
        }
      }

      function resetGame() {
        state = 'running'
        score = 0; tick = 0; speed = 4; spawnIn = 80
        obs = []
        dino.y = GY; dino.vy = 0; dino.grounded = true
        dino.jumps = 0; dino.dead = false; dino.leg = 0; dino.legTimer = 0
        requestAnimationFrame(loop)
      }

      function update() {
        tick++; score++
        speed = Math.min(13, 3 + Math.pow(score / 600, 0.85))

        // Dino physics
        const CEILING = 66 // cat ear tips at y-56; keep 10px buffer from canvas top
        if (!dino.grounded) {
          dino.vy += 0.75
          dino.y  += dino.vy
          if (dino.y <= CEILING) {
            dino.y = CEILING
            if (dino.vy < 0) dino.vy = 0
          }
          if (dino.y >= GY) {
            dino.y = GY; dino.vy = 0
            dino.grounded = true; dino.jumps = 0
          }
        }

        // Leg animation
        if (dino.grounded) {
          dino.legTimer++
          if (dino.legTimer > 7) { dino.leg = 1 - dino.leg; dino.legTimer = 0 }
        }

        // Clouds (slow scroll)
        clouds.forEach(c => { c.x -= 0.6 })
        clouds = clouds.filter(c => c.x + c.w > -20)
        if (clouds.length < 3) {
          clouds.push({ x: W + 20, y: 28 + Math.random() * 56, w: 50 + Math.random() * 50 })
        }

        // Spawn obstacles
        spawnIn--
        if (spawnIn <= 0) {
          const h = 44 + Math.random() * 52
          const w = 18 + Math.random() * 14
          obs.push({ x: W + 10, w, h })
          // Occasionally spawn a pair
          if (Math.random() > 0.55 && score > 400) {
            obs.push({ x: W + 10 + w + 10 + Math.random() * 18, w: 14 + Math.random() * 10, h: 36 + Math.random() * 36 })
          }
          const base = Math.max(32, 80 - Math.floor(score / 300) * 4)
          spawnIn = base + Math.floor(Math.random() * 40)
        }

        obs.forEach(o => { o.x -= speed })
        obs = obs.filter(o => o.x + o.w > -10)

        // Collision (tighter hitbox than visual)
        const dx1 = 75 + 8, dy1 = dino.y - 46
        const dx2 = 75 + 32, dy2 = dino.y - 4
        for (const o of obs) {
          if (dx2 > o.x + 3 && dx1 < o.x + o.w - 3 && dy2 > GY - o.h + 4 && dy1 < GY) {
            dino.dead = true
            state = 'dead'
            hiScore = Math.max(hiScore, score)
            return
          }
        }
      }

      function drawCloud(c: Cloud) {
        ctx.fillStyle = 'rgba(255,255,255,0.03)'
        ctx.beginPath()
        ctx.ellipse(c.x + c.w * 0.25, c.y,      c.w * 0.28, 9,  0, 0, Math.PI * 2)
        ctx.ellipse(c.x + c.w * 0.55, c.y - 6,  c.w * 0.22, 11, 0, 0, Math.PI * 2)
        ctx.ellipse(c.x + c.w * 0.82, c.y,      c.w * 0.18, 7,  0, 0, Math.PI * 2)
        ctx.fill()
      }

      function drawCat() {
        const x = 75, y = dino.y, f = dino.leg, dead = dino.dead
        const PINK = '#f472b6'

        ctx.fillStyle = DINO

        // Tail (S-curve from body-right going up)
        ctx.fillRect(x + 32, y - 20, 6, 10)   // tail base
        ctx.fillRect(x + 36, y - 34, 6, 16)   // tail going up
        ctx.fillRect(x + 38, y - 42, 8, 10)   // tail curving right
        ctx.fillRect(x + 42, y - 52, 6, 12)   // tail going up again
        ctx.fillRect(x + 36, y - 56, 8, 6)    // tail tip curling left
        ctx.fillRect(x + 30, y - 58, 8, 4)    // tail tip end

        // Body
        ctx.fillRect(x + 1, y - 28, 33, 18)

        // Head
        ctx.fillRect(x + 3, y - 46, 24, 18)
        ctx.fillRect(x + 1, y - 42, 2,  12)   // left side round
        ctx.fillRect(x + 27, y - 42, 2, 12)   // right side round
        ctx.fillRect(x + 5, y - 48, 20, 2)    // head top round

        // Ears
        ctx.fillRect(x + 3,  y - 56, 7, 10)   // left ear
        ctx.fillRect(x + 19, y - 56, 7, 10)   // right ear

        // Inner ears (pink)
        ctx.fillStyle = PINK
        ctx.fillRect(x + 5,  y - 54, 3, 7)
        ctx.fillRect(x + 21, y - 54, 3, 7)

        // Nose (pink)
        ctx.fillRect(x + 13, y - 37, 4, 3)

        // Eyes
        if (dead) {
          ctx.fillStyle = '#f87171'
          ctx.fillRect(x + 6,  y - 43, 3, 3)
          ctx.fillRect(x + 11, y - 38, 3, 3)
          ctx.fillRect(x + 11, y - 43, 3, 3)
          ctx.fillRect(x + 6,  y - 38, 3, 3)
          ctx.fillRect(x + 18, y - 43, 3, 3)
          ctx.fillRect(x + 23, y - 38, 3, 3)
          ctx.fillRect(x + 23, y - 43, 3, 3)
          ctx.fillRect(x + 18, y - 38, 3, 3)
        } else {
          ctx.fillStyle = '#0d0b10'
          ctx.fillRect(x + 6,  y - 43, 5, 5)   // left eye
          ctx.fillRect(x + 18, y - 43, 5, 5)   // right eye
          ctx.fillStyle = '#fff'
          ctx.fillRect(x + 8,  y - 43, 2, 2)   // left shine
          ctx.fillRect(x + 20, y - 43, 2, 2)   // right shine
        }

        // Whiskers
        ctx.fillStyle = 'rgba(255,255,255,0.4)'
        ctx.fillRect(x - 10, y - 36, 12, 1)
        ctx.fillRect(x - 10, y - 33, 12, 1)
        ctx.fillRect(x + 30, y - 36, 12, 1)
        ctx.fillRect(x + 30, y - 33, 12, 1)

        // Legs
        ctx.fillStyle = DINO
        if (dino.grounded && !dead) {
          if (f === 0) {
            ctx.fillRect(x + 4,  y - 10, 8, 10)   // front left extended
            ctx.fillRect(x + 4,  y,      11, 2)   // front paw
            ctx.fillRect(x + 21, y - 10, 8, 5)    // back right tucked
          } else {
            ctx.fillRect(x + 4,  y - 10, 8, 5)    // front left tucked
            ctx.fillRect(x + 21, y - 10, 8, 10)   // back right extended
            ctx.fillRect(x + 21, y,      11, 2)   // back paw
          }
        } else {
          ctx.fillRect(x + 4,  y - 10, 8, 6)      // front legs (jumping)
          ctx.fillRect(x + 21, y - 10, 8, 6)      // back legs (jumping)
        }
      }

      function drawCactus(o: Obstacle) {
        const tw = Math.max(5, Math.round(o.w * 0.28))
        const tx = o.x + Math.round((o.w - tw) / 2)
        const gy = GY

        ctx.fillStyle = CACT

        // Trunk
        ctx.fillRect(tx, gy - o.h, tw, o.h)
        // Cap
        ctx.fillRect(tx - 2, gy - o.h, tw + 4, Math.round(tw * 0.8))

        // Left arm
        const laY = gy - Math.round(o.h * 0.55)
        ctx.fillRect(o.x, laY, tx - o.x, tw)
        ctx.fillRect(o.x, laY - Math.round(o.h * 0.22), tw, Math.round(o.h * 0.22))
        ctx.fillRect(o.x - 2, laY - Math.round(o.h * 0.22), tw + 4, Math.round(tw * 0.8))

        // Right arm
        const raX = tx + tw
        ctx.fillRect(raX, laY, o.x + o.w - raX, tw)
        ctx.fillRect(o.x + o.w - tw, laY - Math.round(o.h * 0.22), tw, Math.round(o.h * 0.22))
        ctx.fillRect(o.x + o.w - tw - 2, laY - Math.round(o.h * 0.22), tw + 4, Math.round(tw * 0.8))

        // Shade stripe
        ctx.fillStyle = CACTS
        ctx.fillRect(tx, gy - o.h, Math.round(tw * 0.35), o.h)
        ctx.fillRect(o.x, laY - Math.round(o.h * 0.22), Math.round(tw * 0.35), Math.round(o.h * 0.22))
        ctx.fillRect(o.x + o.w - tw, laY - Math.round(o.h * 0.22), Math.round(tw * 0.35), Math.round(o.h * 0.22))
      }

      function draw() {
        ctx.fillStyle = BG
        ctx.fillRect(0, 0, W, H)

        clouds.forEach(drawCloud)

        // Ground
        ctx.fillStyle = GND
        ctx.fillRect(0, GY + 2, W, 1)
        ctx.fillStyle = 'rgba(255,255,255,0.03)'
        ctx.fillRect(0, GY + 3, W, 1)

        obs.forEach(drawCactus)
        drawCat()

        // Score
        ctx.font = 'bold 13px "JetBrains Mono", monospace'
        ctx.textAlign = 'right'
        ctx.fillStyle = 'rgba(255,255,255,0.2)'
        ctx.fillText(`HI ${String(hiScore).padStart(5, '0')}`, W - 86, 26)
        ctx.fillStyle = 'rgba(255,255,255,0.55)'
        ctx.fillText(String(score).padStart(5, '0'), W - 18, 26)
        ctx.textAlign = 'left'

        if (state === 'idle') {
          ctx.fillStyle = TXT2
          ctx.font = 'bold 12px "JetBrains Mono", monospace'
          ctx.textAlign = 'center'
          ctx.fillText('— PRESS SPACE OR TAP TO START —', W / 2, H / 2 + 5)
          ctx.textAlign = 'left'
        }

        if (state === 'dead') {
          ctx.fillStyle = 'rgba(0,0,0,0.45)'
          ctx.fillRect(0, 0, W, H)

          ctx.fillStyle = 'rgba(255,255,255,0.88)'
          ctx.font = 'bold 18px "JetBrains Mono", monospace'
          ctx.textAlign = 'center'
          ctx.fillText('G A M E  O V E R', W / 2, H / 2 - 10)

          ctx.fillStyle = TXT2
          ctx.font = '11px "JetBrains Mono", monospace'
          ctx.fillText('PRESS SPACE OR TAP TO RESTART', W / 2, H / 2 + 14)
          ctx.textAlign = 'left'
        }
      }

      function loop() {
        update()
        draw()
        if (state === 'running') requestAnimationFrame(loop)
      }

      draw() // initial idle frame

      // Keyboard
      document.addEventListener('keydown', (e) => {
        if (e.code === 'Space' || e.code === 'ArrowUp') {
          e.preventDefault()
          jump()
        }
      })

      // Touch (tap anywhere except links)
      document.addEventListener('touchstart', (e) => {
        if ((e.target as HTMLElement).closest('a')) return
        e.preventDefault()
        jump()
      }, { passive: false })

      // Click on canvas
      canvas.addEventListener('click', () => jump())
    </script>
  </body>
</html>
