---
import { generateCollectionPaths } from '@/utils/content';
import type { NavLink } from '@/utils/content';
import PostRenderer from '@/components/PostRenderer.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  return generateCollectionPaths('series');
}

type Props = {
  entry: CollectionEntry<'series'>;
  prev: NavLink;
  next: NavLink;
}

const { entry, prev, next } = Astro.props;
---

<PostRenderer entry={entry} prev={prev} next={next} />
