---
import Layout from '@/layouts/Layout.astro'
import { AUTHORS } from '@/constants/authors'

const SocialIcons: Record<string, string> = {
  github: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>',
  linkedin: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>',
  npm: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 12v3H8v-3H5v7h14v-7h-3zM21 8H3v10h18V8zM3 8v-2h18v2"/></svg>',
  ithome: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>',
  default: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>'
}

const getSocialIcon = (key: string) => SocialIcons[key.toLowerCase()] || SocialIcons.default

const splitSummary = (text: string) => {
  if (!text) return { quote: '', author: '' }
  const parts = text.split('\n')
  return {
    quote: parts[0],
    author: parts.length > 1 ? parts[1] : ''
  }
}
---

<Layout title="About">
  <div class="max-w-4xl mx-auto animate-fade-in-up">

    <header class="text-center mb-16 space-y-4">
      <h1 class="font-serif text-4xl md:text-6xl font-semibold tracking-tight text-ink">
        The Author
      </h1>
      <p class="text-ink-faint font-mono text-sm tracking-[0.2em] uppercase">
        Behind the Code
      </p>
    </header>

    <div class="space-y-12">
      
      {AUTHORS.filter(a => !a.isHiddenFromAbout).map((author, index) => {
        const { quote, author: quoteAuthor } = splitSummary(author.summary || '')
        const hasPortfolio = author.portfolio && author.portfolio.length > 0
        
        return (
          <article 
            class={`
              relative group rounded-[32px] p-1
              ${author.isSecret
                ? 'bg-gradient-to-br from-line/60 via-transparent to-line/60'
                : 'bg-gradient-to-br from-line via-line/40 to-transparent hover:from-moss/30 hover:via-moss-soft/20 hover:to-clay/20'}
              transition-all duration-500
            `}
          >
            <div class="h-full bg-cream rounded-[28px] p-8 md:p-10 border border-line relative z-10 overflow-hidden">
              
              <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
                
                {/* Avatar Section */}
                <div class="shrink-0 mx-auto md:mx-0 relative md:sticky md:top-10">
                  <div class={`
                    relative w-32 h-32 md:w-40 md:h-40 rounded-full p-1
                    ${author.isSecret ? 'border-2 border-dashed border-ink/15' : 'bg-gradient-to-tr from-moss-soft/40 to-transparent shadow-xl shadow-ink/10'}
                  `}>
                    <img 
                      src={author.imgPath} 
                      alt={author.name} 
                      class={`
                        w-full h-full object-cover rounded-full
                        transition-all duration-700
                        ${author.isSecret
                          ? 'grayscale contrast-125 brightness-90'
                          : 'group-hover:scale-105 ring-4 ring-cream'}
                      `}
                    />
                    
                    {author.isSecret && (
                      <div class="absolute -bottom-2 -right-2 z-20">
                        <span class="flex items-center gap-1.5 bg-paper px-3 py-1 text-[10px] font-mono text-clay border border-clay/40 rounded-full backdrop-blur-md shadow-md">
                          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                          LOCKED
                        </span>
                      </div>
                    )}
                  </div>
                </div>

                {/* Content Section */}
                <div class="flex-1 min-w-0 text-center md:text-left space-y-6 w-full">
                  
                  {/* Name & Role */}
                  <div>
                    <h2
                      class={`text-5xl md:text-6xl font-bold mb-3 leading-none ${author.isSecret ? 'text-ink/20' : 'text-ink'}`}
                      style="font-family: 'Caveat', cursive"
                    >
                      {author.name}
                    </h2>
                    
                    {!author.isSecret ? (
                      <div class="flex flex-wrap gap-2 justify-center md:justify-start">
                        {author.currentRole?.map(role => (
                          <span class="text-[10px] font-bold tracking-wider uppercase px-2 py-0.5 rounded border border-moss/25 text-moss bg-moss/5">
                            {role}
                          </span>
                        ))}
                      </div>
                    ) : (
                      <div class="flex items-center justify-center md:justify-start gap-2 opacity-60">
                          <span class="bg-ink/15 text-transparent rounded px-2 select-none text-xs">UNKNOWN ROLE</span>
                          <span class="text-[10px] font-mono text-ink-faint uppercase tracking-widest">[ REDACTED ]</span>
                      </div>
                    )}
                  </div>

                  {/* Description / Secret Message */}
                  <div class="prose prose-sm max-w-none text-ink-soft whitespace-pre-line leading-relaxed">
                    {author.isSecret ? (
                        <div class="py-4 pl-4 border-l-2 border-line space-y-3">
                          <p class="text-ink-faint font-mono text-xs leading-loose">
                            &gt; Accessing user profile... <span class="text-clay">DENIED</span><br/>
                            &gt; Decrypting bio... <span class="text-clay">FAILED</span><br/>
                            &gt; Status: <span class="text-ink-soft">Character not yet unlocked.</span>
                          </p>
                          <p class="text-ink-soft text-sm italic pt-2">
                            "This profile appears to be encrypted.<br/>Please check back later... or perhaps try to find the key?" 🤫
                          </p>
                        </div>
                    ) : (
                      <>
                        {quote && (
                          <div class="mb-6">
                            <p class="font-serif text-ink text-lg md:text-xl font-medium italic leading-relaxed">
                              "{quote}"
                            </p>
                            {quoteAuthor && (
                              <p class="text-ink-faint text-sm mt-2 font-mono text-right">
                                {quoteAuthor}
                              </p>
                            )}
                          </div>
                        )}
                        <p>{author.description}</p>
                      </>
                    )}
                  </div>

                  {/* Tech Stack & Links & Portfolio */}
                  {!author.isSecret && (
                    <div class="pt-6 border-t border-line flex flex-col items-center md:items-start gap-6">
                      <div class="w-full flex flex-col md:flex-row items-center md:justify-between gap-6">
                        
                        {/* Stack */}
                        {author.programmingLanguages && (
                          <div class="flex flex-wrap gap-2 justify-center">
                            {author.programmingLanguages.map(lang => (
                              <span class="px-3 py-1 text-xs font-medium rounded-full bg-paper text-ink-soft border border-line">
                                {lang}
                              </span>
                            ))}
                          </div>
                        )}

                        {/* Socials */}
                        {author.socialLinks && (
                          <div class="flex gap-4">
                            {Object.entries(author.socialLinks).map(([platform, url]) => (
                              <a 
                                href={url} 
                                target="_blank" 
                                rel="noopener noreferrer"
                                class="text-ink-faint hover:text-moss transition-colors p-2 hover:bg-ink/5 rounded-full"
                                title={platform}
                                aria-label={platform}
                              >
                                <Fragment set:html={getSocialIcon(platform)} />
                              </a>
                            ))}
                          </div>
                        )}
                      </div>
                      
                      {/* Portfolio */}
                      {hasPortfolio && (
                        <div class="w-full pt-2">
                           <button
                            class="portfolio-trigger group/btn flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-ink-faint hover:text-moss transition-colors"
                            data-target={`portfolio-${index}`}
                            aria-expanded="false"
                            aria-controls={`portfolio-${index}`}
                           >
                            <span>Featured Projects</span>
                            <svg 
                              xmlns="http://www.w3.org/2000/svg" 
                              width="14" height="14" 
                              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                              class="transform transition-transform duration-300 group-data-[expanded=true]/btn:rotate-180"
                            >
                              <path d="m6 9 6 6 6-6"/>
                            </svg>
                           </button>

                           <div 
                              id={`portfolio-${index}`} 
                              class="portfolio-content grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-out"
                           >
                              <div class="overflow-hidden">
                                <div class="pt-6 grid gap-4">
                                  {author.portfolio?.map(project => (
                                    <a 
                                      href={project.link}
                                      target="_blank"
                                      rel="noopener noreferrer"
                                      class="
                                        group/card block p-5 rounded-xl bg-paper border border-line
                                        hover:border-moss/40 hover:shadow-[0_4px_20px_-10px_rgba(95,115,85,0.35)]
                                        transition-all duration-300
                                      "
                                    >
                                      <div class="flex items-start justify-between mb-2">
                                        <h3 class="font-bold text-ink group-hover/card:text-moss transition-colors">
                                          {project.name}
                                        </h3>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink-faint group-hover/card:text-moss group-hover/card:translate-x-0.5 group-hover/card:-translate-y-0.5 transition-all"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                                      </div>
                                      <p class="text-xs text-ink-soft leading-relaxed group-hover/card:text-ink whitespace-pre-line">
                                        {project.summary}
                                      </p>
                                    </a>
                                  ))}
                                </div>
                              </div>
                           </div>
                        </div>
                      )}

                    </div>
                  )}

                </div>
              </div>
            </div>
            
            {author.isSecret && (
               <div class="absolute inset-0 bg-noise opacity-[0.08] mix-blend-overlay pointer-events-none rounded-[32px]"></div>
            )}
          </article>
        )
      })}

    </div>
  </div>
</Layout>

<script>
const triggers = document.querySelectorAll('.portfolio-trigger')

triggers.forEach((btn) => {
  btn.addEventListener('click', () => {
    const targetId = btn.getAttribute('data-target')
    if (!targetId) return

    const content = document.getElementById(targetId)
    if (!content) return

    const isExpanded = btn.getAttribute('data-expanded') === 'true'

    btn.setAttribute('data-expanded', (!isExpanded).toString())
    btn.setAttribute('aria-expanded', (!isExpanded).toString())
    
    if (!isExpanded) {
      content.classList.remove('grid-rows-[0fr]')
      content.classList.add('grid-rows-[1fr]')
    } else {
      content.classList.remove('grid-rows-[1fr]')
      content.classList.add('grid-rows-[0fr]')
    }
  })
})
</script>

<style>
  .bg-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.5'/%3E%3C/svg%3E");
  }
</style>