---
import '@/styles/tailwind.css'
import '@/styles/main.scss'
import Menu from '@/components/Menu/Menu.svelte'
import { useMenu } from '@/utils/useMenu'
import CustomCursor from '@/components/CustomCursor.astro'

const { menu } = await useMenu()
const currentPath = Astro.url.pathname

// Caveat and Lora italic are self-hosted in public/fonts/ — keep them out of this request
const FONT_CSS_URL = 'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&family=Lora:wght@400;500;600&family=Noto+Serif+TC:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap'

interface Props {
  title?: string
  description?: string
}

const SITE_NAME = 'Jeremy'

const {
  title = SITE_NAME,
  description = "Jeremy's Tech Blog",
} = Astro.props

const pageTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`
---

<!doctype html>
<html lang="zh-TW" class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Self-hosted brand fonts (declared in main.scss) preloaded so the masthead renders without font swap */}
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/caveat-700-latin.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/lora-italic-400-latin.woff2" />
    {/* Async font CSS keeps the huge CJK stylesheets off the critical render path */}
    <link rel="preload" as="style" href={FONT_CSS_URL} />
    <link rel="stylesheet" href={FONT_CSS_URL} media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href={FONT_CSS_URL} />
    </noscript>
  </head>

  <body
    class="
      min-h-screen
      flex
      flex-col
      text-ink
      bg-paper
      antialiased
      overflow-x-hidden
      selection:bg-moss/20
      selection:text-ink
      relative
    "
  >
    <div class="fixed inset-0 z-[-1] w-full h-full pointer-events-none">
      {/* Radial gradients instead of filter:blur — same glow, no per-frame GPU blur cost on mobile */}
      <div class="absolute top-[-12%] left-[-8%] w-[640px] h-[640px] bg-[radial-gradient(circle_at_center,rgba(139,160,126,0.10),transparent_65%)]"></div>
      <div class="absolute bottom-[-12%] right-[-6%] w-[760px] h-[760px] bg-[radial-gradient(circle_at_center,rgba(179,103,74,0.05),transparent_65%)]"></div>
    </div>

    <Menu client:idle rootItems={menu} currentPath={currentPath} />

    <main class="flex-1 w-full max-w-5xl mx-auto px-6 pt-32 pb-24 relative z-10">
      <slot />
    </main>

    <CustomCursor />

    <style is:global>
      :root {
        color-scheme: light;
      }

      html {
        font-family: 'Inter', 'Noto Sans TC', system-ui, sans-serif;
        scroll-behavior: smooth;
      }

      ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }

      ::-webkit-scrollbar-track {
        background: transparent;
      }

      ::-webkit-scrollbar-thumb {
        background: #d2cfc6;
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: #b7b3a8;
      }

      @media (min-width: 1280px) {
        html, body {
          overflow-x: clip;
        }
      }
    </style>
  </body>
</html>
